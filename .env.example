# ─── EVOKE Reconnect – Environment Variables ───────────────────────────────
# Copy this file to .env (local) and configure Vercel env for production.

# Base URL of your deployed app (no trailing slash)
VITE_BASE_URL=https://evoke-reconnect.vercel.app

# Rishi's WhatsApp number (country code + number, no +, no spaces)
VITE_RISHI_WHATSAPP=919876543210

# Admin dashboard PIN (keep this secret, change from default!)
VITE_ADMIN_PIN=1234

# Google Sheets Webhook URL (optional)
# Set this to your Apps Script Web App URL to push analytics to Sheets.
# Leave blank to use localStorage-only mode.
VITE_SHEETS_ENDPOINT=
